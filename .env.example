# ──────────────────────────────────────────────────────────────────────
#  Nayalogic OS — Environment Variables
# ──────────────────────────────────────────────────────────────────────
#  This file is a TEMPLATE. On first server start, start.js will copy it
#  to .env and auto-generate a JWT_SECRET. You only need to edit .env
#  AFTER it's created to add your ZAI_API_KEY.
# ──────────────────────────────────────────────────────────────────────

# Database — SQLite file stored at ./db/custom.db (auto-created)
# Do NOT change this unless you switch to MySQL/PostgreSQL
DATABASE_URL="file:./db/custom.db"

# JWT Secret — used to sign login tokens
# LEAVE THIS AS-IS. start.js will auto-generate a secure secret on first run.
# (If you want to set your own, replace the placeholder below BEFORE first start.)
JWT_SECRET="REPLACE_ME_START_JS_WILL_GENERATE"

# Server Port
# Hostinger usually sets PORT automatically — leave 3000 as fallback.
PORT=3000

# Public URL of your app (used for CORS, emails, etc.)
# Example: https://app.nayalogic.com
NEXT_PUBLIC_APP_URL=""

# ─── Z.AI API KEY (REQUIRED FOR AI ASSISTANT FEATURE) ───
# Get your key from: https://z.ai/
# Without this, the AI Assistant page will return fallback responses.
ZAI_API_KEY=""
